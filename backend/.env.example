PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/felicity_event_system
JWT_SECRET=change_this_to_a_long_random_secret

# smtp (gmail app password for development)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Felicity Event System <your_email@gmail.com>
# email provider: smtp or resend
EMAIL_PROVIDER=smtp
# resend api key (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# captcha
# set CAPTCHA_ENFORCE=true only after frontend sends captchaToken on login/register
CAPTCHA_ENFORCE=false
# supported: turnstile or recaptcha
CAPTCHA_PROVIDER=turnstile
TURNSTILE_SECRET_KEY=
RECAPTCHA_SECRET_KEY=

# login rate limit (failed attempts)
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_BLOCK_MS=900000

# cas
CAS_ENABLED=false
CAS_LOGIN_URL=https://login.iiit.ac.in/cas/login
CAS_VALIDATE_BASE_URL=https://login-new.iiit.ac.in/cas
CAS_FALLBACK_VALIDATE_BASE_URL=https://login.iiit.ac.in/cas
FRONTEND_BASE_URL=http://localhost:5173
# optional override for callback construction
# BACKEND_BASE_URL=http://localhost:5000
# optional for local tls troubleshooting only
# CAS_ALLOW_INSECURE_TLS=false
